<Window x:Class="TechInventory.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TechInventory.ViewModels"
        Title="TechInventory – Главная"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TreeView Grid.Row="0" ItemsSource="{Binding Buildings}" 
                      BorderThickness="0,0,1,0" BorderBrush="LightGray" Padding="5"
                      SelectedItemChanged="TreeView_SelectedItemChanged">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type vm:BuildingNodeViewModel}" 
                                              ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                    </HierarchicalDataTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:FloorNodeViewModel}" 
                                              ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}"/>
                    </HierarchicalDataTemplate>
                    <DataTemplate DataType="{x:Type vm:RoomNodeViewModel}">
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </TreeView.Resources>
            </TreeView>
            <StackPanel Grid.Row="1" Margin="5,0,5,10">
                <Button Content="📋 Заявки" Click="TicketsButton_Click" Height="30" Margin="0,0,0,5"/>
                <Button Content="+ Заявка" x:Name="CreateTicketFromMainButton" Click="CreateTicketFromMain_Click" Height="30" Margin="0,0,0,5"/>
                <Button Content="📊 Отчёты" Click="ReportsButton_Click" Height="30" Margin="0,0,0,5"/>
                <Button Content="📁 Кабинеты" x:Name="RoomsButton" Click="RoomsButton_Click" Height="30" Margin="0,0,0,5"/>
                <Button Content="📚 Справочники" Click="DictionaryButton_Click" Height="30" Margin="0,0,0,5"/>
                <Button Content="👤 Пользователи" x:Name="UsersButton" Click="UsersButton_Click" Height="30"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding SelectedRoom.RoomName, StringFormat='Кабинет {0}'}" 
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
         Width="150" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemWidth="170" ItemHeight="170"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DeviceTileViewModel}">
                            <Border Margin="6" Padding="12" BorderThickness="1" CornerRadius="12"
            Background="#FEFEFE" Cursor="Hand"
            MouseLeftButtonDown="DeviceTile_Click">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.12"/>
                                </Border.Effect>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasOpenTickets}" Value="True">
                                                <Setter Property="BorderBrush" Value="Red"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                       ToolTip="{Binding Name}"/>
                                    <TextBlock Text="{Binding StatusName}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,2"
                       Foreground="{Binding StatusName, Converter={StaticResource StatusToColorConverter}}"/>
                                    <TextBlock Text=" !" Foreground="Red" FontWeight="Bold" FontSize="14"
                       Visibility="{Binding HasOpenTickets, Converter={StaticResource BoolToVisibilityConverter}}"
                       HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding AssignedTo}" FontSize="10" Foreground="Gray"
                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                       Visibility="{Binding AssignedTo, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>