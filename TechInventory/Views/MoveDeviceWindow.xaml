<Window x:Class="TechInventory.Views.MoveDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Переместить устройство"
        Height="280" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="CurrentRoomText" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Новый кабинет:" VerticalAlignment="Center" Width="100"/>
            <ComboBox x:Name="RoomComboBox" DisplayMemberPath="Name" SelectedValuePath="RoomID"
                      SelectedValue="{Binding SelectedRoomId}" Width="200"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Новая позиция:" VerticalAlignment="Center" Width="100"/>
            <TextBox x:Name="PositionTextBox" Text="{Binding NewPosition, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,5">
            <TextBlock Text="Причина (необязательно):"/>
            <TextBox x:Name="ReasonTextBox" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" 
                     TextWrapping="Wrap" Height="50"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Переместить" Click="MoveButton_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="CancelButton_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>