<Window x:Class="TechInventory.Views.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление пользователями"
        Height="400" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="+ Добавить" Click="AddUser_Click" Width="100" Margin="0,0,10,0"/>
            <Button Content="✎ Редактировать" Click="EditUser_Click" Width="110" Margin="0,0,10,0"/>
            <Button Content="✕ Удалить" Click="DeleteUser_Click" Width="80" Background="LightCoral"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding Users}" x:Name="UsersListView">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" DisplayMemberBinding="{Binding UserID}" Width="40"/>
                    <GridViewColumn Header="Логин" DisplayMemberBinding="{Binding Login}" Width="120"/>
                    <GridViewColumn Header="ФИО" DisplayMemberBinding="{Binding FullName}" Width="200"/>
                    <GridViewColumn Header="Роль" DisplayMemberBinding="{Binding Role}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>