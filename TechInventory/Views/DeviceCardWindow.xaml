<Window x:Class="TechInventory.Views.DeviceCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TechInventory.ViewModels"
        Title="Карточка устройства"
        Height="450" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{Binding Device.Name, StringFormat='Устройство: {0}'}" FontSize="18" FontWeight="Bold"/>
            <TextBlock Margin="0,5,0,0">
                <Run Text="Тип: "/><Run Text="{Binding TypeName}"/>
                <Run Text="{Binding StatusName}" Foreground="{Binding StatusName, Converter={StaticResource StatusToColorConverter}}"/>                <Run Text=" | Закреплён: "/><Run Text="{Binding AssignedUserName}"/>
            </TextBlock>
            <TextBlock Text="{Binding Device.Specs, StringFormat='Характеристики: {0}'}" TextWrapping="Wrap" Margin="0,5,0,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,5" 
                        Visibility="{Binding CanAssign, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="Ответственный:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding AvailableUsers}" SelectedValue="{Binding SelectedUserId}"
                          DisplayMemberPath="FullName" SelectedValuePath="UserID" Width="150" IsEditable="False"/>
                <Button Content="Сохранить" Command="{Binding AssignUserCommand}" Width="80" Margin="5,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Перемещения">
                <ListView ItemsSource="{Binding Movements}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding MoveDate, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="140"/>
                            <GridViewColumn Header="Из кабинета" DisplayMemberBinding="{Binding FromRoom}" Width="80"/>
                            <GridViewColumn Header="В кабинет" DisplayMemberBinding="{Binding ToRoom}" Width="80"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
            <TabItem Header="Заявки">
                <ListView ItemsSource="{Binding Tickets}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ID" DisplayMemberBinding="{Binding TicketID}" Width="40"/>
                            <GridViewColumn Header="Описание" DisplayMemberBinding="{Binding Description}" Width="180"/>
                            <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="80"/>
                            <GridViewColumn Header="Приоритет" DisplayMemberBinding="{Binding Priority}" Width="80"/>
                            <GridViewColumn Header="Кабинет" DisplayMemberBinding="{Binding RoomName}" Width="60"/>
                            <GridViewColumn Header="Создана" DisplayMemberBinding="{Binding CreatedAt}" Width="120"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Переместить" Command="{Binding MoveDeviceCommand}" Width="100" Margin="5,0"
        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="Создать заявку" Command="{Binding CreateTicketCommand}" Width="120" Margin="5,0"
        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="Закрыть" Click="CloseButton_Click" Width="80" Margin="5,0"/>
        </StackPanel>
    </Grid>
</Window>