<Window x:Class="TechInventory.Views.RoomsManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление кабинетами"
        Height="400" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="+ Добавить" Click="Add_Click" Width="100" Margin="0,0,10,0"/>
            <Button Content="✎ Изменить" Click="Edit_Click" Width="100" Margin="0,0,10,0"/>
            <Button Content="✕ Удалить" Click="Delete_Click" Width="80" Background="LightCoral"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="RoomsGrid" AutoGenerateColumns="True" IsReadOnly="True"/>
    </Grid>
</Window>