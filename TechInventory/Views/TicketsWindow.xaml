<Window x:Class="TechInventory.Views.TicketsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TechInventory.ViewModels"
        Title="Лента заявок"
        Height="500" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Приоритет:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding SelectedPriority}" Width="100" Margin="0,0,15,0"/>

            <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Width="100" Margin="0,0,15,0"/>
            <TextBlock Text="Кабинет:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding RoomOptions}" SelectedValue="{Binding SelectedRoomId}"
          DisplayMemberPath="DisplayName" SelectedValuePath="RoomID" Width="100" Margin="0,0,15,0"/>
            
            <Button Content="Обновить" Command="{Binding RefreshCommand}" Width="80"/>
            <Button Content="Закрыть выбранную" Command="{Binding CloseTicketCommand}" Width="120" Margin="10,0,0,0"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding Tickets}" SelectedItem="{Binding SelectedTicket}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" DisplayMemberBinding="{Binding TicketID}" Width="40"/>
                    <GridViewColumn Header="Устройство" DisplayMemberBinding="{Binding DeviceName}" Width="100"/>
                    <GridViewColumn Header="Кабинет" DisplayMemberBinding="{Binding RoomName}" Width="70"/>
                    <GridViewColumn Header="Описание" DisplayMemberBinding="{Binding Description}" Width="200"/>
                    <GridViewColumn Header="Приоритет" DisplayMemberBinding="{Binding Priority}" Width="70"/>
                    <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="80"/>
                    <GridViewColumn Header="Создана" DisplayMemberBinding="{Binding CreatedAt}" Width="120"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>   