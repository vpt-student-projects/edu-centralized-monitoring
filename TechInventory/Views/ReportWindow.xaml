<Window x:Class="TechInventory.Views.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Формирование отчёта"
        Height="180" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите тип отчёта:" FontWeight="Bold" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1">
            <RadioButton x:Name="PurchaseRadio" Content="Для закупки (сломанное оборудование)" Margin="0,5" IsChecked="True"/>
            <RadioButton x:Name="InventoryRadio" Content="Инвентаризационный (все устройства)" Margin="0,5"/>
            <RadioButton x:Name="TicketsRadio" Content="Статистика по заявкам" Margin="0,5"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Grid.Row="1" VerticalAlignment="Bottom">
            <Button Content="Сформировать" Click="GenerateButton_Click" Width="110" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="CancelButton_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>