<Window x:Class="TechInventory.Views.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование пользователя"
        Height="250" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Логин:" Margin="0,5"/>
        <TextBox Grid.Row="0" x:Name="LoginBox" HorizontalAlignment="Right" Width="200" Margin="0,5"/>

        <TextBlock Grid.Row="1" Text="Пароль:" Margin="0,5"/>
        <PasswordBox Grid.Row="1" x:Name="PasswordBox" HorizontalAlignment="Right" Width="200" Margin="0,5"/>

        <TextBlock Grid.Row="2" Text="ФИО:" Margin="0,5"/>
        <TextBox Grid.Row="2" x:Name="FullNameBox" HorizontalAlignment="Right" Width="200" Margin="0,5"/>

        <TextBlock Grid.Row="3" Text="Роль:" Margin="0,5"/>
        <ComboBox Grid.Row="3" x:Name="RoleCombo" HorizontalAlignment="Right" Width="200" Margin="0,5">
            <ComboBoxItem Content="Admin" Tag="Admin"/>
            <ComboBoxItem Content="Teacher" Tag="Teacher" IsSelected="True"/>
        </ComboBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,0,0">
            <Button Content="Сохранить" Click="SaveButton_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="CancelButton_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>