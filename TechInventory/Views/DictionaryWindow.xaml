<Window x:Class="TechInventory.Views.DictionaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Справочники"
        Height="400" Width="650"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CategoryCombo" Width="130" Margin="0,0,15,0"
          SelectedValuePath="Tag">
                <ComboBoxItem Tag="DeviceType">Тип устройства</ComboBoxItem>
                <ComboBoxItem Tag="DeviceStatus">Статус устройства</ComboBoxItem>
                <ComboBoxItem Tag="TicketStatus">Статус заявки</ComboBoxItem>
            </ComboBox>
            <Button Content="+ Добавить" Click="AddItem_Click" Width="100" Margin="0,0,10,0"/>
            <Button Content="✎ Редактировать" Click="EditItem_Click" Width="110" Margin="0,0,10,0"/>
            <Button Content="✕ Удалить" Click="DeleteItem_Click" Width="80" Background="LightCoral"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{Binding Items}" x:Name="ItemsListView">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" DisplayMemberBinding="{Binding ID}" Width="40"/>
                    <GridViewColumn Header="Категория" DisplayMemberBinding="{Binding Category}" Width="120"/>
                    <GridViewColumn Header="Значение" DisplayMemberBinding="{Binding Value}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>